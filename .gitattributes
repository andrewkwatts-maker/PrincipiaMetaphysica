# All website assets in this repository are generated by `metaphysica.build()`
# and treated as generated content by GitHub's language statistics.
index.html                linguist-generated=true
Pages/**                  linguist-generated=true
css/**                    linguist-generated=true
js/**                     linguist-generated=true
components/**             linguist-generated=true
foundations/**            linguist-generated=true
images/**                 linguist-generated=true
AutoGenerated/**          linguist-generated=true
# Normalize line endings: keep generated text as LF on disk; let git work it out per-platform on checkout.
* text=auto eol=lf
*.bat text eol=crlf
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.svg text
